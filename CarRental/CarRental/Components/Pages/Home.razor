@page "/"

@using CarRental.Models
@using Microsoft.EntityFrameworkCore
@inject CarRental.Data.AppDbContext DbContext

<h1>Available cars</h1>

@if (cars is null)
{
    <p>Loading cars...</p>
}
else if (cars.Count == 0)
{
    <p>No cars available.</p>
}
else
{
    <table class="table car-table">
        <thead>
        <tr>
            <th>Photo</th>
            <th>Brand</th>
            <th>Model</th>
            <th>Year</th>
            <th>Daily rate</th>
            <th>Status</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var car in cars)
        {
            var imageUrl = ToDataUrl(car.ImageData, car.ImageContentType);
            <tr>
                <td class="car-photo-cell">
                    @if (!string.IsNullOrWhiteSpace(imageUrl))
                    {
                        <img class="car-photo" src="@imageUrl" alt="@($"{car.Brand} {car.Model}")" />
                    }
                    else
                    {
                        <div class="car-photo-placeholder">No image</div>
                    }
                </td>
                <td>@car.Brand</td>
                <td>@car.Model</td>
                <td>@car.Year</td>
                <td>@car.DailyRate.ToString("C")</td>
                <td>@(car.IsAvailable ? "Available" : "Rented")</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<Car>? cars;

    protected override async Task OnInitializedAsync()
    {
        cars = await DbContext.Cars.AsNoTracking().ToListAsync();
    }

    private static string? ToDataUrl(byte[]? data, string? contentType)
    {
        if (data is null || string.IsNullOrWhiteSpace(contentType))
            return null;

        return $"data:{contentType};base64,{Convert.ToBase64String(data)}";
    }
}
