@page "/"

@using CarRental.Models
@using Microsoft.EntityFrameworkCore
@using CarRental.Services
@inject CarRental.Data.AppDbContext DbContext

<h1>Available cars</h1>

<div class="car-search">
    <input class="car-search-input" placeholder="Search by any field..."
           @bind="searchQuery" @bind:event="oninput" />
</div>

<div class="car-filters">
    <div class="filter-group">
        <div class="filter-header">
            <div class="filter-title">Brand</div>
            <button type="button" class="filter-toggle" @onclick="ToggleBrands">
                @(showBrands ? "Hide" : "Show")
            </button>
        </div>
        @if (showBrands)
        {
            @foreach (var brand in availableBrands)
            {
                <label class="filter-option">
                    <input type="checkbox" checked="@selectedBrands.Contains(brand)" @onchange="() => ToggleSelection(selectedBrands, brand)" />
                    <span>@brand</span>
                </label>
            }
        }
    </div>

    <div class="filter-group">
        <div class="filter-header">
            <div class="filter-title">Model</div>
            <button type="button" class="filter-toggle" @onclick="ToggleModels">
                @(showModels ? "Hide" : "Show")
            </button>
        </div>
        @if (showModels)
        {
            @foreach (var model in availableModels)
            {
                <label class="filter-option">
                    <input type="checkbox" checked="@selectedModels.Contains(model)" @onchange="() => ToggleSelection(selectedModels, model)" />
                    <span>@model</span>
                </label>
            }
        }
    </div>

    <div class="filter-group">
        <div class="filter-header">
            <div class="filter-title">Year</div>
            <button type="button" class="filter-toggle" @onclick="ToggleYears">
                @(showYears ? "Hide" : "Show")
            </button>
        </div>
        @if (showYears)
        {
            @foreach (var year in availableYears)
            {
                <label class="filter-option">
                    <input type="checkbox" checked="@selectedYears.Contains(year)" @onchange="() => ToggleSelection(selectedYears, year)" />
                    <span>@year</span>
                </label>
            }
        }
    </div>

    <div class="filter-group">
        <div class="filter-header">
            <div class="filter-title">Status</div>
            <button type="button" class="filter-toggle" @onclick="ToggleStatuses">
                @(showStatuses ? "Hide" : "Show")
            </button>
        </div>
        @if (showStatuses)
        {
            @foreach (var status in availableStatuses)
            {
                <label class="filter-option">
                    <input type="checkbox" checked="@selectedStatuses.Contains(status)" @onchange="() => ToggleSelection(selectedStatuses, status)" />
                    <span>@status</span>
                </label>
            }
        }
    </div>

    <div class="filter-group">
        <div class="filter-header">
            <div class="filter-title">Max daily rate</div>
        </div>
        <input class="filter-input" placeholder="Max daily rate" @bind="filterMaxRate" @bind:event="oninput" />
    </div>

    <button class="filter-clear" @onclick="ClearFilters">Clear</button>
</div>

@if (cars is null)
{
    <p>Loading cars...</p>
}
else if (cars.Count == 0)
{
    <p>No cars available.</p>
}
else
{
    var filteredCars = CarListFilter.ApplySearchAndFilters(cars, searchQuery, BuildFilterOptions());
    <table class="table car-table">
        <thead>
        <tr>
            <th>Photo</th>
            <th>Brand</th>
            <th>Model</th>
            <th>Year</th>
            <th>Daily rate</th>
            <th>Status</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var car in filteredCars)
        {
            var imageUrl = ToDataUrl(car.ImageData, car.ImageContentType);
            <tr>
                <td class="car-photo-cell">
                    @if (!string.IsNullOrWhiteSpace(imageUrl))
                    {
                        <img class="car-photo" src="@imageUrl" alt="@($"{car.Brand} {car.Model}")" />
                    }
                    else
                    {
                        <div class="car-photo-placeholder">No image</div>
                    }
                </td>
                <td>@car.Brand</td>
                <td>@car.Model</td>
                <td>@car.Year</td>
                <td>@car.DailyRate.ToString("C")</td>
                <td>@(car.IsAvailable ? "Available" : "Rented")</td>
            </tr>
        }
        </tbody>
    </table>

    if (filteredCars.Count == 0)
    {
        <p class="car-search-empty">No cars match your search or filters.</p>
    }
}
@code {
    private List<Car>? cars;
    private string searchQuery = string.Empty;
    private string filterMaxRate = string.Empty;

    private readonly HashSet<string> selectedBrands = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> selectedModels = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> selectedYears = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> selectedStatuses = new(StringComparer.OrdinalIgnoreCase);

    private List<string> availableBrands = new();
    private List<string> availableModels = new();
    private List<string> availableYears = new();
    private List<string> availableStatuses = new();

    private bool showBrands;
    private bool showModels;
    private bool showYears;
    private bool showStatuses;

    protected override async Task OnInitializedAsync()
    {
        cars = await DbContext.Cars.AsNoTracking().ToListAsync();
        InitializeFilterOptions(cars);
    }

    private void InitializeFilterOptions(List<Car> source)
    {
        availableBrands = source.Select(car => car.Brand).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();
        availableModels = source.Select(car => car.Model).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();
        availableYears = source.Select(car => car.Year.ToString()).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();
        availableStatuses = new List<string> { "Available", "Rented" };

        selectedBrands.Clear();
        selectedModels.Clear();
        selectedYears.Clear();
        selectedStatuses.Clear();
    }

    private CarFilterOptions BuildFilterOptions()
    {
        var options = new CarFilterOptions { MaxRate = filterMaxRate };

        foreach (var brand in selectedBrands) options.SelectedBrands.Add(brand);
        foreach (var model in selectedModels) options.SelectedModels.Add(model);
        foreach (var year in selectedYears) options.SelectedYears.Add(year);
        foreach (var status in selectedStatuses) options.SelectedStatuses.Add(status);

        return options;
    }

    private void ToggleSelection(HashSet<string> selections, string value)
    {
        if (!selections.Add(value))
            selections.Remove(value);
    }

    private void ClearFilters()
    {
        searchQuery = string.Empty;
        filterMaxRate = string.Empty;

        selectedBrands.Clear();
        selectedModels.Clear();
        selectedYears.Clear();
        selectedStatuses.Clear();
        
        showBrands = false;
        showModels = false;
        showYears = false;
        showStatuses = false;
    }

    private void ToggleBrands() => showBrands = !showBrands;
    private void ToggleModels() => showModels = !showModels;
    private void ToggleYears() => showYears = !showYears;
    private void ToggleStatuses() => showStatuses = !showStatuses;

    private static string? ToDataUrl(byte[]? data, string? contentType)
    {
        if (data is null || string.IsNullOrWhiteSpace(contentType))
            return null;

        return $"data:{contentType};base64,{Convert.ToBase64String(data)}";
    }
}
