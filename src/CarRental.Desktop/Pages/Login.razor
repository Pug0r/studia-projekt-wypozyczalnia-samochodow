@page "/"

<PageTitle>Login</PageTitle>

<div class="login-card">
    <h1>Car Rental</h1>
    <p class="subtitle">Login (example view)</p>

    <EditForm Model="this">
        <div class="field">
            <label for="email">Email</label>
            <InputText id="email" class="input" />
        </div>

        <div class="field">
            <label for="password">Password</label>
            <InputText id="password" class="input" type="password" />
        </div>

        <button type="submit" class="button">Sign in</button>
    </EditForm>
</div>
