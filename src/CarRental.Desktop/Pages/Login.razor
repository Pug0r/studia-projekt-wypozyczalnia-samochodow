@page "/"
@using System.ComponentModel.DataAnnotations

<PageTitle>Login</PageTitle>

<div class="login-card">
    <h1>Car Rental</h1>
    <p class="subtitle">Login (example view)</p>

    <EditForm Model="_model">
        <DataAnnotationsValidator />

        <div class="field">
            <label for="email">Email</label>
            <InputText id="email" class="input" @bind-Value="_model.Email" />
        </div>

        <div class="field">
            <label for="password">Password</label>
            <InputText id="password" class="input" type="password" @bind-Value="_model.Password" />
        </div>

        <button type="submit" class="button">Sign in</button>
    </EditForm>
</div>

@code {
    private readonly LoginViewModel _model = new();

    private sealed class LoginViewModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        [MinLength(8)]
        public string Password { get; set; } = string.Empty;
    }
}
